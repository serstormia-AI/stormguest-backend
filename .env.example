# =============================================================
# stormguest-backend — Variables de Entorno
# Copiá este archivo como .env y completá los valores reales.
# NUNCA hagas commit del archivo .env al repositorio.
# =============================================================

# ── REQUERIDAS (el servidor no arranca sin estas) ─────────────
PORT=3000
NODE_ENV=production

# Supabase → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Generá con: openssl rand -hex 64
JWT_SECRET=cambia_esto_por_un_string_largo_y_aleatorio

# ── SEGURIDAD ─────────────────────────────────────────────────
# Necesario para cifrar claves Stripe y PMS por hotel (AES-256-GCM)
# Generá con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ── CORS ──────────────────────────────────────────────────────
# URL del dashboard en Vercel. Separar varios con coma.
CORS_ORIGINS=https://tu-dashboard.vercel.app

# ── CLAUDE AI ─────────────────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── WHATSAPP (Twilio) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# URL pública del backend para recibir mensajes entrantes
TWILIO_WEBHOOK_URL=https://tu-backend.up.railway.app/api/webhook/twilio

# ── EMAIL — fallback global (cada hotel puede tener el suyo) ──
# Si no se configura, los emails no se envían (no rompe la app)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu@gmail.com
EMAIL_PASS=
EMAIL_FROM=StormGuest <tu@gmail.com>

# ── STRIPE — fallback global (cada hotel puede tener el suyo) ─
# Si no se configura, /api/payments/checkout responde 503
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
FRONTEND_URL=https://tu-dashboard.vercel.app
