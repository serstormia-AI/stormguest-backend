# =============================================================
# stormguest-backend — Variables de Entorno
# Copiá este archivo como .env y completá los valores reales.
# NUNCA hagas commit del archivo .env al repositorio.
# =============================================================


# -------------------------------------------------------------
# SERVIDOR
# -------------------------------------------------------------

PORT=8080
NODE_ENV=production


# -------------------------------------------------------------
# JWT
# Usado por middleware/auth.js y routes/auth.js para firmar y verificar tokens
# Generá un secreto seguro con: openssl rand -hex 64
# -------------------------------------------------------------

JWT_SECRET=cambia_esto_por_una_clave_larga_y_aleatoria


# -------------------------------------------------------------
# BASE DE DATOS — PostgreSQL directo
# Usado por database.js con el paquete 'pg'
# Supabase → Project Settings → Database → Connection string → URI
# Usá port 5432 para conexiones persistentes.
# -------------------------------------------------------------

DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DB_SCHEMA=public


# -------------------------------------------------------------
# SUPABASE (SDK)
# Usado por services/supabaseClient.js y services/chatBot.js
# Supabase → Project Settings → API
# -------------------------------------------------------------

# URL del proyecto
SUPABASE_URL=https://tu-proyecto.supabase.co

# Service Role Key — PRIVADA, bypasa RLS, nunca al frontend
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key


# -------------------------------------------------------------
# CORS
# En producción es obligatorio. Lista de orígenes separados por coma.
# -------------------------------------------------------------

CORS_ORIGINS=https://tu-frontend.vercel.app


# -------------------------------------------------------------
# ANTHROPIC (Claude AI)
# Usado por services/scheduler.js para mensajes automáticos
# https://console.anthropic.com/settings/keys
# -------------------------------------------------------------

ANTHROPIC_API_KEY=sk-ant-api03-...


# -------------------------------------------------------------
# OPENAI
# Usado por services/claudeAI.js (bot de conversaciones)
# https://platform.openai.com/api-keys
# -------------------------------------------------------------

OPENAI_API_KEY=sk-proj-...


# -------------------------------------------------------------
# WHATSAPP
# Proveedor activo: 'mock' | 'twilio' | 'evolution'
# -------------------------------------------------------------

WHATSAPP_PROVIDER=mock

# -- Twilio (requerido si WHATSAPP_PROVIDER=twilio) --
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# -- Evolution API (requerido si WHATSAPP_PROVIDER=evolution) --
EVOLUTION_URL=https://evo.tudominio.com
EVOLUTION_API_KEY=tu-evolution-api-key
EVOLUTION_INSTANCE=stormguest-default

# -- Meta Business API (requerido si WHATSAPP_PROVIDER=meta) --
META_VERIFY_TOKEN=tu-token-de-verificacion-meta

# URL pública del webhook (debe ser accesible desde internet)
WEBHOOK_URL=https://api.tudominio.com/webhook


# -------------------------------------------------------------
# EMAIL — Nodemailer / SMTP
# Usado por services/emailService.js para notificaciones a huéspedes
# Si no se configura, los emails no se envían (no rompe la app)
# -------------------------------------------------------------

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu@email.com
EMAIL_PASS=tu_app_password
EMAIL_FROM=StormGuest <noreply@tuhotel.com>


# -------------------------------------------------------------
# STRIPE — Pagos (opcional)
# Usado por routes/payments.js
# Si STRIPE_SECRET_KEY no está definida, el endpoint /api/payments/checkout
# responde 503. El resto de la app funciona normalmente.
# https://dashboard.stripe.com/apikeys
# -------------------------------------------------------------

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
FRONTEND_URL=https://tu-frontend.vercel.app
