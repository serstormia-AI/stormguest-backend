# =============================================================
# stormguest-backend — Variables de Entorno
# Copiá este archivo como .env y completá los valores reales.
# NUNCA commits el archivo .env al repositorio.
# =============================================================


# -------------------------------------------------------------
# SERVIDOR
# -------------------------------------------------------------

# Puerto en el que escucha el servidor Express
PORT=3001


# -------------------------------------------------------------
# BASE DE DATOS (PostgreSQL directo)
# Usado por database.js con el paquete 'pg'
# Obtené la cadena de conexión desde:
#   Supabase → Project Settings → Database → Connection string → URI
# Asegurate de usar la cadena con modo "Transaction" (port 6543) si usás PgBouncer,
# o la directa (port 5432) para conexiones persistentes.
# -------------------------------------------------------------

DATABASE_URL=postgresql://postgres:[TU_PASSWORD]@db.[TU_PROJECT_REF].supabase.co:5432/postgres

# Schema de búsqueda por defecto (normalmente "public")
DB_SCHEMA=public


# -------------------------------------------------------------
# SUPABASE (SDK — para Realtime, RPC, tabla access)
# Usado por services/supabaseClient.js y services/chatBot.js
# Obtené los valores en: Supabase → Project Settings → API
# -------------------------------------------------------------

# URL del proyecto (ej: https://abcdefghijkl.supabase.co)
SUPABASE_URL=https://[TU_PROJECT_REF].supabase.co

# Service Role Key (¡PRIVADA! Tiene acceso completo, bypasa RLS)
# Supabase → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# -------------------------------------------------------------
# AUTENTICACIÓN JWT
# Usado por middleware/auth.js y routes/auth.js para firmar y verificar tokens
#
# ⚠️  MOVER AQUÍ — actualmente hardcodeado como fallback en:
#     middleware/auth.js:18  → 'stormguest_secret_123'
#     routes/auth.js:33      → 'stormguest_secret_123'
#
# Generá un secreto seguro con: openssl rand -hex 64
# -------------------------------------------------------------

JWT_SECRET=cambia_este_secreto_por_uno_largo_y_aleatorio


# -------------------------------------------------------------
# AI — OpenAI
# Usado por services/claudeAI.js (que en realidad usa la librería openai)
# Obtené tu key en: https://platform.openai.com/api-keys
# -------------------------------------------------------------

OPENAI_API_KEY=sk-proj-...


# -------------------------------------------------------------
# AI — Anthropic / Claude
# Usado por services/scheduler.js para generar mensajes automáticos
# Obtené tu key en: https://console.anthropic.com/settings/keys
# -------------------------------------------------------------

ANTHROPIC_API_KEY=sk-ant-api03-...


# -------------------------------------------------------------
# WHATSAPP
# Proveedor activo: 'mock' | 'meta' | 'evolution'
# Usado por services/whatsapp.js
# -------------------------------------------------------------

# Seleccioná el proveedor de WhatsApp
WHATSAPP_PROVIDER=mock

# -- Evolution API (requerido si WHATSAPP_PROVIDER=evolution) --
# URL base de tu instancia de Evolution API (ej: https://evo.tudominio.com)
EVOLUTION_URL=https://evo.tudominio.com

# Global API Key de Evolution API (Settings → Authentication)
EVOLUTION_API_KEY=tu-evolution-api-key

# Nombre de la instancia Evolution por defecto (se usa como fallback en sendMessage)
EVOLUTION_INSTANCE=stormguest-default

# -- Meta Business API (requerido si WHATSAPP_PROVIDER=meta) --
# Token de verificación del webhook (lo elegís vos al configurar el webhook en Meta)
META_VERIFY_TOKEN=tu-token-de-verificacion-meta

# -- URL pública del webhook (usada al crear nuevas instancias Evolution) --
# Debe ser accesible desde internet (usá ngrok en desarrollo)
WEBHOOK_URL=https://api.tudominio.com/webhook
